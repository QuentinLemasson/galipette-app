{
  "name": "galipette-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build:api": "pnpm --filter api build",
    "generate:openapi": "pnpm --filter api generate:openapi",
    "build:content-schema": "pnpm --filter @galipette/content-schema build",
    "build:content-parser": "pnpm --filter @galipette/content-parser build",
    "build:content-resolver": "pnpm --filter @galipette/content-resolver build",
    "build:content-builder": "pnpm --filter @galipette/content-builder build",
    "build:compiled-content": "pnpm --filter @galipette/compiled-content build",
    "build:database": "pnpm --filter @galipette/database build",
    "build:shared-schemas": "pnpm --filter @galipette/shared-schemas build",
    "db:generate": "pnpm --filter @galipette/database db:generate",
    "db:validate": "pnpm --filter @galipette/database db:validate",
    "db:migrate": "pnpm --filter @galipette/database db:migrate",
    "db:deploy": "pnpm --filter @galipette/database db:deploy",
    "db:push": "pnpm --filter @galipette/database db:push",
    "db:studio": "pnpm --filter @galipette/database db:studio",
    "db:status": "pnpm --filter @galipette/database db:status",
    "db:reset": "pnpm --filter @galipette/database db:reset",
    "build:content": "pnpm build:content-schema && pnpm build:content-parser && pnpm build:content-resolver && pnpm build:content-builder && pnpm build:compiled-content",
    "test:content-schema": "pnpm --filter @galipette/content-schema test",
    "test:content-builder": "pnpm --filter @galipette/content-builder test",
    "test:compiled-content": "pnpm --filter @galipette/compiled-content test",
    "test:content": "pnpm test:content-schema && pnpm test:content-builder && pnpm test:compiled-content",
    "create-invite-link": "pnpm tsx scripts/create-invite-link.ts $1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.9",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "create-vite": "^9.0.6",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
