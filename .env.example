# Copy to `.env` at the repository root (or under `packages/content-builder/`).
# The content-builder script loads these files automatically when you run `pnpm build:content`.
# Variables you already set in the terminal take precedence; `.env` only fills gaps.
#
# Observability: paths should use forward slashes or escaped backslashes on Windows.

# Absolute path to the Obsidian vault directory on your machine.
OBSIDIAN_VAULT_PATH=

# Subfolder inside the vault to scan (relative to the vault root). Example: entities or notes/spells
OBSIDIAN_VAULT_SUBFOLDER=
