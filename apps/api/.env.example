# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/galipette?schema=public"
# PORT=3001

# Better Auth (API origin — session cookies are set on this host)
# BETTER_AUTH_SECRET=change-me
# BETTER_AUTH_URL=http://localhost:3001

# Discord OAuth
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# Comma-separated browser origins allowed for CORS (Vite dev default below)
# WEB_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Invite OAuth debug logs ([invite] lines in API stdout). Set to false to disable.
# INVITE_DEBUG=true
